{
	"$schema": "https://zed.dev/schema/themes/v0.2.0.json",
	"name": "Poimandres Light",
	"author": "matiadev",
	"themes": [
		{
			"name": "Poimandres Light",
			"appearance": "light",
			"style": {
				"background": "#edededff",
				"surface.background": "#1b1e28ff",
				"element.background": "#e3e3e3ff",
				"text": "#474747ff",
				"text.muted": "#666666ff",
				"status_bar.background": "#edededff",
				"title_bar.background": "#edededff",
				"toolbar.background": "#edededff",
				"tab_bar.background": "#1b1e28ff",
				"tab.active_background": "#ededed80",
				"tab.inactive_background": "#edededff",
				"panel.background": "#edededff",
				"editor.background": "#edededff",
				"editor.gutter.background": "#edededff",
				"editor.subheader.background": "#f5f5f5ff",
				"error": "#d0679dff",
				"error.background": "#d0679d20",
				"hint": "#3f596eb3",
				"info": "#47acffff",
				"info.background": "#add7ff3b",
				"modified": "#1c9bffff",
				"warning": "#94910aff",
				"warning.background": "#d0ce6720",
				"terminal.background": "#edededff",
				"syntax": {
					"attribute": {
						"color": "#5e7a91ff"
					},
					"boolean": {
						"color": "#00c798ff"
					},
					"comment": {
						"color": "#666666b0"
					},
					"constant": {
						"color": "#00c798ff"
					},
					"function": {
						"color": "#219dffff"
					},
					"keyword": {
						"color": "#424242ff"
					},
					"number": {
						"color": "#00c798ff"
					},
					"property": {
						"color": "#474747ff"
					},
					"string": {
						"color": "#00cca1ff"
					},
					"tag": {
						"color": "#00cca1ff"
					},
					"type": {
						"color": "#707070ff"
					},
					"variable": {
						"color": "#3f7199ff"
					},
					"variable.special": {
						"color": "#4d6c8fff"
					}
				},
				"panel.overlay_hover": "#edededff",
				"version_control.modified": "#1c9bffff"
			}
		}
	]
}
